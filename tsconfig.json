{
  "extends": "@tsconfig/node18",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "outDir": "build",
    "baseUrl": "src",
    "paths": {
      "*": ["node_modules/*", "src/types/*", "node_modules/@aws-lite/ssm-types/*"]
    },
    "types": ["@aws-lite/ssm-types"]
  },
  "include": ["src/**/*"]
}
